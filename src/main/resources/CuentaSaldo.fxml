<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<?import javafx.scene.layout.VBox?>
<AnchorPane prefHeight="1080.0" prefWidth="1920.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.CuentaSaldoController">
   <children>
      <ImageView fx:id="imgLogo" fitHeight="150.0" fitWidth="742.0" layoutX="486.0" layoutY="89.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@images/account.png" />
         </image>
      </ImageView>
      <Label fx:id="lblTitulo" layoutX="696.0" layoutY="86.0" prefHeight="78.0" prefWidth="560.0" text="Consulta de cuentas">
         <font>
            <Font name="System Bold" size="55.0" />
         </font>
      </Label>
      <Label fx:id="lblSubtitulo" layoutX="696.0" layoutY="164.0" prefHeight="57.0" prefWidth="754.0" text=" Seleccione la cuenta que desea utilizar">
         <font>
            <Font size="35.0" />
         </font>
      </Label>
      <?import javafx.scene.layout.VBox?>

      <ScrollPane fx:id="scrollCuentas"
                  layoutX="462.0"
                  layoutY="239.0"
                  prefHeight="707.0"
                  prefWidth="996.0"
                  fitToWidth="true">

         <content>
            <VBox fx:id="contenedorCuentas"
                  spacing="15"
                  prefWidth="960.0"/>
         </content>

      </ScrollPane>
      <Button fx:id="btnRegresar" layoutX="462.0" layoutY="961.0" mnemonicParsing="false" onAction="#volverMenu" prefHeight="83.0" prefWidth="996.0" text=" ← REGRESAR">
         <font>
            <Font name="System Bold" size="40.0" />
         </font>
      </Button>
   </children>
</AnchorPane>
